---
import Glyph from "./Glyph.astro";

interface Props {
  state?: "locked" | "ready" | "decrypting" | "error" | "revealed";
}

const { state = "locked" } = Astro.props;
const isReady = state === "ready";
const isRevealed = state === "revealed";
const hasPrefilledKey = state !== "locked";
const status = {
  locked: "Composez la clé visuelle du fragment.",
  ready: "Combinaison prête.",
  decrypting: "Le texte se stabilise.",
  error: "Aucune ouverture pour cette combinaison.",
  revealed: "Fragment déchiffré.",
}[state];
const cipher =
  "iVPi0MB5Q8ODMSg8PWu8zVdGau7kGq3v7tIQQYpuZSuJJb0VTm6E1iLJGp3cxYz1ufQ39W6wXlC+Lh4aXkWQZlL2cnq4v9cHc9E0pF8+uN7cWV9";
const previewGlyphs = [
  { colors: ["#d95f43", "#2aa198", "#455a7f", "#234f68"] },
  { colors: ["#f2b84b", "#256d85", "#8f5b3e", "#2f5f9b"] },
];
---

<article
  class:list={[
    "entry-article",
    "sealed-entry",
    state === "decrypting" && "is-decrypting",
    state === "error" && "is-decrypt-error",
    isRevealed && "is-revealed",
  ]}
>
  <header class="entry-header">
    <Glyph seed="GBT-H052" />
    <p class="entry-id">{isRevealed ? "GBT-H052" : "FRAGMENT SCELLÉ"}</p>
    <h1>{isRevealed ? "Signal ambre" : "Fragment scellé"}</h1>
    <p class="entry-excerpt">
      {
        isRevealed
          ? "Un court fragment débloqué par deux objets qui ne produisent de lumière qu'ensemble."
          : "Le contenu existe, mais pas encore sous une forme lisible."
      }
    </p>
    {isRevealed && <div class="entry-meta">07/06/2026 · fragment · text</div>}
  </header>

  {
    !isRevealed && (
      <section class="sealed-seal">
        <div class="sealed-cipher-block">
          <p class="sealed-label">Texte chiffré</p>
          <pre>{cipher}</pre>
        </div>

        <div class="sealed-key-panel">
          <div class="sealed-key-panel-head">
            <p>Composition des glyphes</p>
          </div>
          <div class="sealed-key-slots">
            {previewGlyphs.map((glyph, index) => (
              <div
                class:list={[
                  "sealed-glyph-slot",
                  !hasPrefilledKey && "is-empty",
                  hasPrefilledKey && index === 0 && "is-picker-open",
                  hasPrefilledKey && "is-complete",
                ]}
              >
                <div
                  class="sealed-glyph-instrument"
                  style={{
                    "--glyph-a": glyph.colors[0],
                    "--glyph-b": glyph.colors[1],
                    "--glyph-c": glyph.colors[2],
                    "--glyph-d": glyph.colors[3],
                  }}
                >
                  <div class="sealed-glyph-orb">
                    <Glyph seed={`preview-${index}`} colors={glyph.colors} filledSegments={hasPrefilledKey ? [true, true, true, true] : [false, false, false, false]} />
                    {[0, 1, 2, 3].map((colorIndex) => (
                      <button
                        class="sealed-glyph-segment"
                        type="button"
                        aria-pressed={colorIndex === 0 && index === 0}
                        data-glyph-segment={colorIndex}
                        data-glyph-id={`${index}:${colorIndex}`}
                      />
                    ))}
                  </div>
                </div>
                {
                  hasPrefilledKey && index === 0 && (
                    <div class="sealed-color-popover" aria-label={`Palette du glyphe ${index + 1}`}>
                      <div class="sealed-palette">
                        {[
                          "#d95f43",
                          "#f2b84b",
                          "#e07a5f",
                          "#b94e5e",
                          "#2aa198",
                          "#256d85",
                          "#3d7c68",
                          "#4f8fa8",
                          "#455a7f",
                          "#8f5b3e",
                          "#5d4b7a",
                          "#7b5ea7",
                          "#234f68",
                          "#2f5f9b",
                          "#35675f",
                          "#3f4a7a",
                        ].map((color) => (
                          <button
                            class="sealed-color-swatch"
                            type="button"
                            aria-pressed={glyph.colors[0] === color}
                            style={{ "--swatch-color": color }}
                          />
                        ))}
                      </div>
                    </div>
                  )
                }
              </div>
            ))}
          </div>
          <div class="sealed-key-actions">
            <button class="secret-decrypt-button" type="button" hidden={!isReady} disabled={!isReady}>
              {state === "decrypting" ? "Déchiffrement..." : "Déchiffrer"}
            </button>
            <p class="secret-status">{status}</p>
          </div>
        </div>
      </section>
    )
  }

  <section class="entry-content sealed-plain" hidden={!isRevealed}>
    <div class="secret-fragment-body">
      <p>La pièce semble vide jusqu'à ce que la lumière glisse sur le bord du plan.</p>
      <p>Trois fragments suffisent à rendre le texte lisible.</p>
    </div>
  </section>
  <button class="sealed-debug-button sealed-reset-after" type="button" hidden={!isRevealed}>Resceller</button>
</article>
