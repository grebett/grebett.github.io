---
import { getFragmentGlyph } from "../data/glyph";

interface Props {
  seed: string;
  colors?: string[];
  rotation?: number;
}

const { seed, colors: providedColors, rotation: providedRotation } = Astro.props;
const generated = getFragmentGlyph(seed);
const colors = providedColors ?? generated.colors;
const rotation = providedRotation ?? generated.rotation;
const style = {
  "--glyph-rotation": `${rotation}deg`,
  "--glyph-a": colors[0],
  "--glyph-b": colors[1],
  "--glyph-c": colors[2],
  "--glyph-d": colors[3],
};
---

<span class="glyph" aria-hidden="true" style={style}></span>
