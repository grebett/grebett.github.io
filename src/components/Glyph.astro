---
import { getFragmentGlyph } from "../data/glyph";

interface Props {
  seed: string;
}

const { seed } = Astro.props;
const { colors, rotation } = getFragmentGlyph(seed);
const style = {
  "--glyph-rotation": `${rotation}deg`,
  "--glyph-a": colors[0],
  "--glyph-b": colors[1],
  "--glyph-c": colors[2],
  "--glyph-d": colors[3],
};
---

<span class="glyph" aria-hidden="true" style={style}></span>
