---
import Glyph from "./Glyph.astro";
import type { CollectionEntry } from "astro:content";

interface Props {
  entry: CollectionEntry<"entries">;
  stateClass?: string;
  style?: Record<string, string>;
}

const { entry, stateClass, style } = Astro.props;
const { id, title, date, type, tags, excerpt, medium, stack, stacks } = entry.data;
const entryDate = new Date(date);
const year = String(entryDate.getFullYear());
const haystack = [title, type, year, excerpt, ...tags, ...medium].join(" ").toLowerCase();
const stackRecipes = stacks ?? (stack ? [stack] : []);
const primaryStack = stackRecipes[0];
---

<article
  class:list={["entry-card", stateClass]}
  style={style}
  data-entry-card
  data-type={type}
  data-year={year}
  data-tags={tags.join("|")}
  data-medium={medium.join("|")}
  data-search-text={haystack}
  data-entry-key={entry.id}
  data-stack-id={primaryStack?.id}
  data-stack-target={primaryStack?.target}
  data-stack-required={primaryStack?.required.join("|")}
  data-stack-recipes={JSON.stringify(stackRecipes)}
  data-drop-enabled={stackRecipes.length > 0}
>
  <a href={`/entries/${entry.id}/`} aria-label={`Lire ${title}`} draggable="false">
    <div class="card-topline">
      <Glyph seed={id} />
      <span>{id}</span>
    </div>
    <h2>{title}</h2>
    <p>{excerpt}</p>
    <div class="entry-meta">
      <time datetime={entryDate.toISOString()}>{entryDate.toLocaleDateString("fr-FR")}</time>
      <span>{type}</span>
    </div>
    <div class="medium-row" aria-label="Médias">
      {medium.map((item) => <span>{item}</span>)}
    </div>
    <div class="tag-row" aria-label="Tags">
      {tags.map((tag) => <span>{tag}</span>)}
    </div>
  </a>
  {
    stackRecipes.length > 0 && (
      <button class="card-drag-handle" type="button" aria-label="Déplacer le fragment" data-card-drag-handle>
        <span></span>
        <span></span>
        <span></span>
      </button>
    )
  }
</article>
