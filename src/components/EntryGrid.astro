---
import EntryCard from "./EntryCard.astro";
import type { CollectionEntry } from "astro:content";

interface Props {
  entries: CollectionEntry<"entries">[];
}

const { entries } = Astro.props;
---

<section class="entry-grid" aria-describedby="archive-results-status">
  {entries.map((entry) => <EntryCard entry={entry} />)}
  <p class="empty-state" id="archive-results-status" data-empty-state role="status" hidden>
    Aucun fragment ne correspond à cette constellation.
  </p>
</section>
