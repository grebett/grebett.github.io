---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import EntryGrid from "../components/EntryGrid.astro";
import SearchBox from "../components/SearchBox.astro";
import TagFilter from "../components/TagFilter.astro";

const entries = (
  await getCollection("entries", ({ data }) => data.status === "public")
).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const unique = (values: string[]) =>
  [...new Set(values)].sort((a, b) => a.localeCompare(b, "fr"));
const tags = unique(entries.flatMap((entry) => entry.data.tags));
const types = unique(entries.map((entry) => entry.data.type));
const media = unique(entries.flatMap((entry) => entry.data.medium));
const years = unique(
  entries.map((entry) => String(entry.data.date.getFullYear())),
).reverse();
---

<BaseLayout>
  <main class="archive-shell">
    <header class="archive-header">
      <p class="site-mark">GREBETT</p>
      <h1>Archives personnelles</h1>
      <p>Description</p>
    </header>

    <section class="archive-tools" aria-label="Filtres de l'archive">
      <SearchBox />
      <TagFilter label="Type" name="type" values={types} />
      <TagFilter label="Média" name="medium" values={media} />
      <TagFilter label="Année" name="year" values={years} />
      <TagFilter label="Tags" name="tags" values={tags} />
    </section>

    <EntryGrid entries={entries} />
  </main>

  <div class="mobile-stack-zone" data-mobile-stack-zone aria-hidden="true">
    <div class="mobile-stack-zone-inner">
      <span class="mobile-stack-zone-mark">STACK</span>
      <span class="mobile-stack-zone-count" data-mobile-stack-count></span>
    </div>
  </div>

  <script>
    const search = document.querySelector<HTMLInputElement>("[data-search]");
    const cards = [
      ...document.querySelectorAll<HTMLElement>("[data-entry-card]"),
    ];
    const emptyState =
      document.querySelector<HTMLElement>("[data-empty-state]");
    const filters = [
      ...document.querySelectorAll<HTMLInputElement>("[data-filter]"),
    ];

    const activeValues = (name: string) =>
      filters
        .filter((input) => input.dataset.filter === name && input.checked)
        .map((input) => input.value);

    const includesAny = (source: string | undefined, selected: string[]) => {
      if (selected.length === 0) return true;
      const values = source?.split("|").filter(Boolean) ?? [];
      return selected.some((value) => values.includes(value));
    };

    const filterNames = ["type", "medium", "year", "tags"] as const;
    type FilterName = (typeof filterNames)[number];

    const isFilterName = (value: string | undefined): value is FilterName =>
      filterNames.includes(value as FilterName);

    const readUrlState = () => {
      const params = new URLSearchParams(window.location.search);
      return {
        q: params.get("q") ?? "",
        type: params.getAll("type"),
        medium: params.getAll("medium"),
        year: params.getAll("year"),
        tags: params.getAll("tags"),
      };
    };

    const applyUrlState = () => {
      if (!search) return;

      const state = readUrlState();
      search.value = state.q;
      filters.forEach((input) => {
        const name = input.dataset.filter;
        input.checked = isFilterName(name) && state[name].includes(input.value);
      });
    };

    const writeUrlState = () => {
      if (!search) return;

      const params = new URLSearchParams();
      const query = search.value.trim();
      if (query) params.set("q", query);

      filterNames.forEach((name) => {
        activeValues(name).forEach((value) => params.append(name, value));
      });

      const nextUrl = `${window.location.pathname}${params.toString() ? `?${params}` : ""}`;
      window.history.replaceState(null, "", nextUrl);
    };

    const updateArchive = ({ syncUrl = true } = {}) => {
      if (!search || !emptyState) return;

      const query = search.value.trim().toLowerCase();
      const selected = {
        type: activeValues("type"),
        medium: activeValues("medium"),
        year: activeValues("year"),
        tags: activeValues("tags"),
      };

      let visible = 0;
      cards.forEach((card) => {
        const matches =
          (card.dataset.searchText ?? "").includes(query) &&
          includesAny(card.dataset.type, selected.type) &&
          includesAny(card.dataset.medium, selected.medium) &&
          includesAny(card.dataset.year, selected.year) &&
          includesAny(card.dataset.tags, selected.tags);

        card.hidden = !matches;
        if (matches) visible += 1;
      });

      emptyState.hidden = visible !== 0;
      if (syncUrl) writeUrlState();
    };

    applyUrlState();
    updateArchive({ syncUrl: false });

    search?.addEventListener("input", () => updateArchive());
    filters.forEach((input) => input.addEventListener("change", () => updateArchive()));
    window.addEventListener("popstate", () => {
      applyUrlState();
      updateArchive({ syncUrl: false });
    });

    const dragThreshold = 8;
    const stackState = new Map<string, Set<string>>();
    const stackAnchors = new Map<string, HTMLElement>();
    const stackOrder = new Map<string, string[]>();
    const isCoarsePointer = window.matchMedia("(pointer: coarse)").matches;
    const mobileStackZone = document.querySelector<HTMLElement>("[data-mobile-stack-zone]");
    const mobileStackCount = document.querySelector<HTMLElement>("[data-mobile-stack-count]");
    let mobileStackTarget: string | null = null;
    let dragState:
      | {
          card: HTMLElement;
          pointerId: number;
          downX: number;
          downY: number;
          currentX: number;
          currentY: number;
          originX: number;
          originY: number;
          active: boolean;
          mode: "desktop" | "mobile";
          sourceStackTarget?: string;
        }
      | null = null;

    const getRequiredStackItems = (card: HTMLElement) =>
      card.dataset.stackRequired?.split("|").filter(Boolean) ?? [];

    const isStackParticipant = (card: HTMLElement) => {
      const entryKey = card.dataset.entryKey ?? "";
      return card.dataset.dropEnabled === "true" && getRequiredStackItems(card).includes(entryKey);
    };

    const getRequiredItemsForTarget = (targetSlug: string) => {
      const targetCard = cards.find((card) => card.dataset.stackTarget === targetSlug);
      return targetCard ? getRequiredStackItems(targetCard) : [];
    };

    const acceptsDrop = (target: HTMLElement, dragged: HTMLElement | null) => {
      if (!dragged || target === dragged) return false;
      if (target.dataset.dropEnabled !== "true") return false;
      if (!target.dataset.stackTarget) return false;

      const required = getRequiredStackItems(target);
      const targetKey = target.dataset.entryKey ?? "";
      const draggedKey = dragged.dataset.entryKey ?? "";
      return required.includes(targetKey) && required.includes(draggedKey);
    };

    const isInCurrentMobileStack = (card: HTMLElement) => {
      const entryKey = card.dataset.entryKey ?? "";
      return Boolean(
        mobileStackTarget &&
          card.dataset.currentStackTarget === mobileStackTarget &&
          stackState.get(mobileStackTarget)?.has(entryKey),
      );
    };

    const mobileZoneAccepts = (card: HTMLElement | null) => {
      if (!mobileStackZone || !card) return false;
      if (isInCurrentMobileStack(card)) return true;

      const targetSlug = card.dataset.stackTarget;
      const entryKey = card.dataset.entryKey;
      if (!targetSlug || !entryKey || !isStackParticipant(card)) return false;
      if (mobileStackTarget && mobileStackTarget !== targetSlug) return false;
      return !stackState.get(targetSlug)?.has(entryKey);
    };

    const clearDropTargets = () => {
      cards.forEach((card) => card.classList.remove("is-drop-target"));
      mobileStackZone?.classList.remove("is-drop-target");
    };

    const setMobileZoneDragging = (active: boolean) => {
      document.documentElement.classList.toggle("is-mobile-stack-dragging", active);
      mobileStackZone?.setAttribute("aria-hidden", active ? "false" : "true");
    };

    const syncMobileStackZone = () => {
      if (!mobileStackZone) return;
      if (mobileStackTarget && !stackState.has(mobileStackTarget)) mobileStackTarget = null;

      const stack = mobileStackTarget ? stackState.get(mobileStackTarget) : undefined;
      const hasStack = Boolean(stack?.size);
      const requiredCount = mobileStackTarget ? getRequiredItemsForTarget(mobileStackTarget).length : 0;

      mobileStackZone.classList.toggle("has-stack", hasStack);
      document.documentElement.classList.toggle("has-mobile-stack", hasStack);
      mobileStackZone.setAttribute("aria-hidden", hasStack ? "false" : "true");
      if (mobileStackCount) mobileStackCount.textContent = hasStack ? `${stack?.size ?? 0}/${requiredCount}` : "";
    };

    const readCardX = (card: HTMLElement) => Number.parseFloat(card.style.getPropertyValue("--drag-x")) || 0;
    const readCardY = (card: HTMLElement) => Number.parseFloat(card.style.getPropertyValue("--drag-y")) || 0;

    const getVisualCenter = (element: HTMLElement) => {
      const rect = element.getBoundingClientRect();
      return {
        x: rect.left + rect.width / 2,
        y: rect.top + rect.height / 2,
      };
    };

    const getLayoutCenter = (card: HTMLElement) => {
      const parent = card.offsetParent as HTMLElement | null;
      if (!parent) return getVisualCenter(card);

      const parentRect = parent.getBoundingClientRect();
      return {
        x: parentRect.left + card.offsetLeft + card.offsetWidth / 2,
        y: parentRect.top + card.offsetTop + card.offsetHeight / 2,
      };
    };

    const getAnchorCenter = (anchor: HTMLElement) => {
      if (anchor === mobileStackZone) return getVisualCenter(anchor);
      return getLayoutCenter(anchor);
    };

    const setCardTransform = (card: HTMLElement, x: number, y: number, rotation = 0) => {
      card.style.setProperty("--drag-x", `${x}px`);
      card.style.setProperty("--drag-y", `${y}px`);
      card.style.setProperty("--stack-rotation", `${rotation}deg`);
    };

    const clearCardTransform = (card: HTMLElement) => {
      card.style.removeProperty("--drag-x");
      card.style.removeProperty("--drag-y");
      card.style.removeProperty("--stack-rotation");
    };

    const clearStackMembership = (card: HTMLElement, clearTransform = true) => {
      delete card.dataset.currentStackTarget;
      delete card.dataset.stackIndex;
      card.classList.remove("is-stacked", "is-stack-top", "just-stacked");
      if (clearTransform) clearCardTransform(card);
    };

    const removeFromStack = (card: HTMLElement, options: { clearTransform?: boolean } = {}) => {
      const { clearTransform = true } = options;
      const entryKey = card.dataset.entryKey;
      const targetSlug = card.dataset.currentStackTarget;
      if (!entryKey || !targetSlug) return;

      const stack = stackState.get(targetSlug);
      stack?.delete(entryKey);

      const order = stackOrder.get(targetSlug)?.filter((key) => key !== entryKey) ?? [];
      if (order.length > 1) {
        stackOrder.set(targetSlug, order);
      } else {
        stackState.delete(targetSlug);
        stackOrder.delete(targetSlug);
        stackAnchors.delete(targetSlug);
        if (mobileStackTarget === targetSlug) mobileStackTarget = null;

        const remainingCard = cards.find((candidate) => candidate.dataset.entryKey === order[0]);
        if (remainingCard) clearStackMembership(remainingCard);
      }

      clearStackMembership(card, clearTransform);
      syncMobileStackZone();
    };

    const updateStackVisuals = (targetSlug: string) => {
      const stack = stackState.get(targetSlug) ?? new Set<string>();
      const anchor = stackAnchors.get(targetSlug);
      const order = stackOrder.get(targetSlug) ?? [...stack];
      if (!anchor) return;

      const anchorCenter = getAnchorCenter(anchor);
      order.forEach((entryKey, index) => {
        const card = cards.find((candidate) => candidate.dataset.entryKey === entryKey);
        if (!card) return;

        const center = getLayoutCenter(card);
        const offsetX = [0, 4, -5, 7, -3][index % 5];
        const offsetY = [0, -3, 5, 2, -6][index % 5];
        const rotation = [0, -1.4, 1.1, -0.8, 1.6][index % 5];
        setCardTransform(card, anchorCenter.x - center.x + offsetX, anchorCenter.y - center.y + offsetY, rotation);
        card.dataset.currentStackTarget = targetSlug;
        card.dataset.stackIndex = String(index);
        card.classList.add("is-stacked");
        card.classList.toggle("is-stack-top", index === order.length - 1);
      });
    };

    const completeStack = (targetSlug: string, required: string[]) => {
      const stack = stackState.get(targetSlug);
      if (!stack) return;

      const isComplete = required.every((entryKey) => stack.has(entryKey));
      if (!isComplete) return;

      cards.forEach((card) => {
        if (stack.has(card.dataset.entryKey ?? "")) card.classList.add("is-fusing");
      });

      window.setTimeout(() => {
        window.location.href = `/entries/${targetSlug}/`;
      }, 760);
    };

    const addCardToStack = (targetSlug: string, card: HTMLElement) => {
      const stack = stackState.get(targetSlug) ?? new Set<string>();
      const order = stackOrder.get(targetSlug) ?? [];
      const entryKey = card.dataset.entryKey;
      if (!entryKey || stack.has(entryKey)) return;

      stack.add(entryKey);
      order.push(entryKey);
      stackState.set(targetSlug, stack);
      stackOrder.set(targetSlug, order);
    };

    const stackCardOnTarget = (dragged: HTMLElement, target: HTMLElement) => {
      const sourceStackTarget = dragged.dataset.currentStackTarget;
      if (sourceStackTarget) removeFromStack(dragged, { clearTransform: false });

      const targetSlug = target.dataset.stackTarget;
      if (!targetSlug) return;

      if (!stackAnchors.has(targetSlug)) stackAnchors.set(targetSlug, target);
      addCardToStack(targetSlug, target);
      addCardToStack(targetSlug, dragged);

      target.classList.add("just-stacked");
      dragged.classList.add("just-stacked");
      window.setTimeout(() => {
        target.classList.remove("just-stacked");
        dragged.classList.remove("just-stacked");
      }, 420);
      updateStackVisuals(targetSlug);
      completeStack(targetSlug, getRequiredStackItems(target));
    };

    const stackCardInMobileZone = (card: HTMLElement) => {
      if (!mobileStackZone || !mobileZoneAccepts(card)) return;

      const sourceStackTarget = card.dataset.currentStackTarget;
      if (sourceStackTarget) removeFromStack(card, { clearTransform: false });

      const targetSlug = card.dataset.stackTarget;
      if (!targetSlug) return;

      mobileStackTarget = targetSlug;
      if (!stackAnchors.has(targetSlug)) stackAnchors.set(targetSlug, mobileStackZone);
      addCardToStack(targetSlug, card);

      card.classList.add("just-stacked");
      window.setTimeout(() => card.classList.remove("just-stacked"), 420);
      updateStackVisuals(targetSlug);
      syncMobileStackZone();
      completeStack(targetSlug, getRequiredStackItems(card));
    };

    const findDropTarget = (x: number, y: number) => {
      if (dragState) dragState.card.style.pointerEvents = "none";
      const element = document.elementFromPoint(x, y);
      if (dragState) dragState.card.style.pointerEvents = "";
      return element?.closest<HTMLElement>("[data-entry-card]") ?? null;
    };

    const isPointerOverMobileZone = () => {
      if (!dragState || !mobileStackZone) return false;
      dragState.card.style.pointerEvents = "none";
      const element = document.elementFromPoint(dragState.currentX, dragState.currentY);
      dragState.card.style.pointerEvents = "";
      return Boolean(element?.closest("[data-mobile-stack-zone]"));
    };

    const updateDropTarget = () => {
      if (!dragState?.active) return null;
      clearDropTargets();
      const target = findDropTarget(dragState.currentX, dragState.currentY);
      if (target && acceptsDrop(target, dragState.card)) {
        target.classList.add("is-drop-target");
        return target;
      }
      return null;
    };

    const updateMobileDropZone = () => {
      if (!dragState?.active || !mobileStackZone) return false;
      const accepts = mobileZoneAccepts(dragState.card);
      const isDropTarget = accepts && isPointerOverMobileZone();
      mobileStackZone.classList.toggle("is-drop-target", isDropTarget);
      return isDropTarget;
    };

    const activateDrag = () => {
      if (!dragState || dragState.active) return;
      dragState.active = true;
      dragState.card.classList.add("is-dragging");
      document.documentElement.classList.add("is-card-dragging");
      if (dragState.mode === "mobile") {
        dragState.card.dataset.suppressClick = "true";
        setMobileZoneDragging(true);
      }
    };

    const startDesktopDrag = (card: HTMLElement, event: PointerEvent) => {
      if (event.button !== 0) return;

      const sourceStackTarget = card.dataset.currentStackTarget;
      const isStacked = Boolean(sourceStackTarget);
      const isTopCard = !isStacked || card.classList.contains("is-stack-top");
      if (!isTopCard) return;

      dragState = {
        card,
        pointerId: event.pointerId,
        downX: event.clientX,
        downY: event.clientY,
        currentX: event.clientX,
        currentY: event.clientY,
        originX: readCardX(card),
        originY: readCardY(card),
        active: false,
        mode: "desktop",
        sourceStackTarget,
      };
    };

    const startMobileDrag = (card: HTMLElement, event: PointerEvent) => {
      if (!isCoarsePointer) return;
      if (event.button !== 0) return;

      const sourceStackTarget = card.dataset.currentStackTarget;
      const isStacked = Boolean(sourceStackTarget);
      const isTopCard = !isStacked || card.classList.contains("is-stack-top");
      if (!isTopCard) return;
      if (!sourceStackTarget && !isStackParticipant(card)) return;

      dragState = {
        card,
        pointerId: event.pointerId,
        downX: event.clientX,
        downY: event.clientY,
        currentX: event.clientX,
        currentY: event.clientY,
        originX: readCardX(card),
        originY: readCardY(card),
        active: false,
        mode: "mobile",
        sourceStackTarget,
      };
    };

    const moveDrag = (event: PointerEvent) => {
      if (!dragState || event.pointerId !== dragState.pointerId) return;

      const totalX = event.clientX - dragState.downX;
      const totalY = event.clientY - dragState.downY;
      dragState.currentX = event.clientX;
      dragState.currentY = event.clientY;

      if (!dragState.active) {
        if (Math.hypot(totalX, totalY) < dragThreshold) return;
        activateDrag();
      }

      event.preventDefault();
      setCardTransform(dragState.card, dragState.originX + totalX, dragState.originY + totalY);
      if (dragState.mode === "mobile") updateMobileDropZone();
      else updateDropTarget();
    };

    const finishDrag = (event: PointerEvent) => {
      if (!dragState || event.pointerId !== dragState.pointerId) return;
      const { card, active, mode, sourceStackTarget } = dragState;
      const target = active && mode === "desktop" ? updateDropTarget() : null;
      const isMobileDrop = active && mode === "mobile" ? updateMobileDropZone() : false;
      clearDropTargets();
      card.classList.remove("is-dragging");
      document.documentElement.classList.remove("is-card-dragging");
      if (mode === "mobile") setMobileZoneDragging(false);

      if (active && mode === "mobile" && isMobileDrop) {
        if (isInCurrentMobileStack(card) && sourceStackTarget) updateStackVisuals(sourceStackTarget);
        else stackCardInMobileZone(card);
      } else if (active && mode === "desktop" && target && acceptsDrop(target, card)) {
        stackCardOnTarget(card, target);
      } else if (active && sourceStackTarget) {
        removeFromStack(card);
        updateStackVisuals(sourceStackTarget);
        syncMobileStackZone();
      } else if (active) {
        clearCardTransform(card);
      } else if (sourceStackTarget) {
        updateStackVisuals(sourceStackTarget);
      }

      if (active) {
        card.dataset.suppressClick = "true";
        window.setTimeout(() => {
          delete card.dataset.suppressClick;
        }, 180);
      } else {
        delete card.dataset.suppressClick;
      }

      dragState = null;
      syncMobileStackZone();
    };

    const refreshMobileStackVisuals = () => {
      if (mobileStackTarget) updateStackVisuals(mobileStackTarget);
    };

    syncMobileStackZone();
    window.addEventListener("scroll", refreshMobileStackVisuals, { passive: true });
    window.addEventListener("resize", refreshMobileStackVisuals);

    cards.forEach((card) => {
      if (isCoarsePointer) {
        card.addEventListener("pointerdown", (event) => startMobileDrag(card, event));
        card.addEventListener("contextmenu", (event) => {
          if (isStackParticipant(card)) event.preventDefault();
        });
      } else {
        card.addEventListener("pointerdown", (event) => startDesktopDrag(card, event));
      }

      card.addEventListener("click", (event) => {
        if (card.dataset.suppressClick === "true") event.preventDefault();
      });
    });
    document.addEventListener("pointermove", moveDrag);
    document.addEventListener("pointerup", finishDrag);
    document.addEventListener("pointercancel", finishDrag);
  </script>
</BaseLayout>
