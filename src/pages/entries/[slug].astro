---
import { getCollection, render } from "astro:content";
import EntryLayout from "../../layouts/EntryLayout.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Glyph from "../../components/Glyph.astro";
import { sealedColorOptions } from "../../data/sealed";

export async function getStaticPaths() {
  const entries = await getCollection("entries", ({ data }) => data.status !== "draft");
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const isSealed = entry.data.status === "sealed";
const rendered = isSealed ? null : await render(entry);
const Content = rendered?.Content;
---

{
  isSealed ? (
    <BaseLayout title="Fragment scellé | GREBETT" description="Un fragment chiffré attend sa combinaison.">
      <main class="entry-shell">
        <a class="back-link" href="/">Retour à l'archive</a>

        <article
          class="entry-article sealed-entry"
          data-sealed-entry
          data-sealed-slug={entry.id}
          data-sealed-colors={JSON.stringify(sealedColorOptions)}
        >
          <header class="entry-header">
            <Glyph seed={entry.data.id} filledSegments={[false, false, false, false]} />
            <p class="entry-id" data-sealed-entry-id>FRAGMENT SCELLÉ</p>
            <h1 data-sealed-title>Fragment scellé</h1>
            <p class="entry-excerpt" data-sealed-excerpt>
              Le contenu existe, mais pas encore sous une forme lisible.
            </p>
            <div class="entry-meta" data-sealed-meta hidden></div>
            <div class="tag-row" data-sealed-tags aria-label="Tags" hidden></div>
          </header>

          <section class="sealed-seal" data-sealed-seal>
            <div class="sealed-cipher-block">
              <p class="sealed-label">Texte chiffré</p>
              <pre data-sealed-cipher>Chargement du fragment chiffré...</pre>
            </div>

            <div class="sealed-key-panel" data-sealed-key-panel>
              <div class="sealed-key-panel-head">
                <p>Composition des glyphes</p>
              </div>
              <div class="sealed-key-slots" data-sealed-key-slots></div>
              <div class="sealed-key-actions">
                <button class="secret-decrypt-button" type="button" data-sealed-decrypt hidden disabled>
                  Déchiffrer
                </button>
                <p class="secret-status" data-sealed-status>Composez la clé visuelle du fragment.</p>
              </div>
            </div>
          </section>

          <section class="entry-content sealed-plain" data-sealed-plain hidden></section>
          <button class="sealed-debug-button sealed-reset-after" type="button" data-sealed-reset hidden>
            Resceller
          </button>
        </article>
      </main>

      <script>
        const sealedEntry = document.querySelector<HTMLElement>("[data-sealed-entry]");
        const sealedSeal = document.querySelector<HTMLElement>("[data-sealed-seal]");
        const sealedEntryId = document.querySelector<HTMLElement>("[data-sealed-entry-id]");
        const sealedTitle = document.querySelector<HTMLElement>("[data-sealed-title]");
        const sealedExcerpt = document.querySelector<HTMLElement>("[data-sealed-excerpt]");
        const sealedMeta = document.querySelector<HTMLElement>("[data-sealed-meta]");
        const sealedTags = document.querySelector<HTMLElement>("[data-sealed-tags]");
        const sealedCipher = document.querySelector<HTMLElement>("[data-sealed-cipher]");
        const sealedDecrypt = document.querySelector<HTMLButtonElement>("[data-sealed-decrypt]");
        const sealedReset = document.querySelector<HTMLButtonElement>("[data-sealed-reset]");
        const sealedStatus = document.querySelector<HTMLElement>("[data-sealed-status]");
        const sealedPlain = document.querySelector<HTMLElement>("[data-sealed-plain]");
        const sealedKeySlots = document.querySelector<HTMLElement>("[data-sealed-key-slots]");
        const sealedSlug = sealedEntry?.dataset.sealedSlug ?? "";
        const colorOptions = JSON.parse(sealedEntry?.dataset.sealedColors ?? "[]") as string[];
        const initialHeader = {
          id: sealedEntryId?.textContent ?? "",
          title: sealedTitle?.textContent ?? "",
          excerpt: sealedExcerpt?.textContent ?? "",
        };
        const keyStorageKey = `sealed-key:${sealedSlug}`;
        const revealedStorageKey = `sealed-revealed:${sealedSlug}`;
        let sealedPayload: {
          slots: number;
          iterations: number;
          salt: string;
          iv: string;
          ciphertext: string;
        } | null = null;
        let glyphs: SealedGlyph[] = [];
        let filledSegments: boolean[][] = [];
        let validationId = 0;
        let validationTimer: number | undefined;
        let unlockedFragment: FragmentPayload | null = null;
        let unlockedPassphrase = "";
        let activeColorTarget: { glyphIndex: number; colorIndex: number } | null = null;
        let closingColorTarget: { glyphIndex: number; colorIndex: number } | null = null;
        let pickerCloseTimer: number | undefined;
        let shouldAnimatePicker = false;

        type SealedGlyph = {
          colors: string[];
        };

        type FragmentPayload = {
          id: string;
          title: string;
          excerpt: string;
          date: string;
          type: string;
          medium: string[];
          tags: string[];
          body: string;
        };

        const fromBase64 = (value: string) => Uint8Array.from(atob(value), (character) => character.charCodeAt(0));

        const escapeHtml = (value: string) =>
          value.replaceAll("&", "&amp;").replaceAll("<", "&lt;").replaceAll(">", "&gt;").replaceAll('"', "&quot;");

        const renderInlineMarkdown = (value: string) =>
          escapeHtml(value).replace(/`([^`]+)`/g, "<code>$1</code>");

        const renderSecretBody = (body: string) =>
          body
            .trim()
            .split(/\n{2,}/)
            .map((paragraph) => `<p>${renderInlineMarkdown(paragraph.replace(/\n/g, " "))}</p>`)
            .join("");

        const normalizeGlyph = (glyph: SealedGlyph): SealedGlyph => ({
          colors: [0, 1, 2, 3].map((index) => (glyph.colors[index] ?? colorOptions[index] ?? "#000000").toLowerCase()),
        });

        const getSealedPassphrase = (items: SealedGlyph[]) =>
          items
            .map((glyph) => {
              const normalized = normalizeGlyph(glyph);
              return normalized.colors.join(",");
            })
            .join("|");

        const getDefaultGlyph = (): SealedGlyph => ({
          colors: colorOptions.slice(0, 4),
        });

        const getEmptySegments = (count: number, filled: boolean) =>
          Array.from({ length: count }, () => [filled, filled, filled, filled]);
        const hasAnyFilledSegment = (index: number) => filledSegments[index]?.some(Boolean) ?? false;
        const isGlyphComplete = (index: number) => filledSegments[index]?.every(Boolean) ?? false;
        const areGlyphsComplete = () => glyphs.length > 0 && glyphs.every((_, index) => isGlyphComplete(index));

        const decryptPayload = async (passphrase: string) => {
          if (!sealedPayload) throw new Error("missing payload");

          const keyMaterial = await crypto.subtle.importKey(
            "raw",
            new TextEncoder().encode(passphrase),
            "PBKDF2",
            false,
            ["deriveKey"],
          );
          const key = await crypto.subtle.deriveKey(
            {
              name: "PBKDF2",
              salt: fromBase64(sealedPayload.salt),
              iterations: sealedPayload.iterations,
              hash: "SHA-256",
            },
            keyMaterial,
            { name: "AES-GCM", length: 256 },
            false,
            ["decrypt"],
          );
          const decrypted = await crypto.subtle.decrypt(
            { name: "AES-GCM", iv: fromBase64(sealedPayload.iv) },
            key,
            fromBase64(sealedPayload.ciphertext),
          );

          return JSON.parse(new TextDecoder().decode(decrypted)) as FragmentPayload;
        };

        const readStoredFragment = () => {
          try {
            const stored = window.localStorage.getItem(revealedStorageKey);
            return stored ? (JSON.parse(stored) as Awaited<ReturnType<typeof decryptPayload>>) : null;
          } catch {
            return null;
          }
        };

        const storeFragment = (fragment: Awaited<ReturnType<typeof decryptPayload>>) => {
          try {
            window.localStorage.setItem(revealedStorageKey, JSON.stringify(fragment));
          } catch {
            // Revealing should still work even when localStorage is unavailable.
          }
        };

        const readStoredKey = () => {
          try {
            const stored = window.localStorage.getItem(keyStorageKey);
            if (!stored) return null;

            const parsed = JSON.parse(stored) as { glyphs?: SealedGlyph[]; passphrase?: string };
            if (!Array.isArray(parsed.glyphs)) return null;
            return parsed;
          } catch {
            return null;
          }
        };

        const storeKey = (items: SealedGlyph[], passphrase: string) => {
          try {
            window.localStorage.setItem(keyStorageKey, JSON.stringify({ glyphs: items, passphrase }));
          } catch {
            // The revealed fragment can still be read during this session.
          }
        };

        const clearStoredKey = () => {
          try {
            window.localStorage.removeItem(keyStorageKey);
          } catch {
            // Ignore storage failures.
          }
        };

        const clearStoredFragment = () => {
          try {
            window.localStorage.removeItem(revealedStorageKey);
          } catch {
            // Ignore storage failures.
          }
        };

        const sleep = (delay: number) => new Promise((resolve) => window.setTimeout(resolve, delay));

        const clearDecryptionState = () => {
          sealedEntry?.classList.remove("is-decrypting", "is-reading", "is-condensing");
        };

        const playDecryptionRitual = async () => {
          sealedEntry?.classList.add("is-decrypting", "is-reading");
          sealedStatus && (sealedStatus.textContent = "Lecture du fragment.");
          await sleep(420);
          sealedEntry?.classList.remove("is-reading");
          sealedEntry?.classList.add("is-condensing");
          sealedStatus && (sealedStatus.textContent = "Le texte se stabilise.");
          await sleep(620);
        };

        const renderDecryptedFragment = (fragment: FragmentPayload, options: { animate?: boolean } = {}) => {
          if (!sealedPlain || !sealedDecrypt || !sealedStatus) return;

          const date = new Date(fragment.date).toLocaleDateString("fr-FR");
          const headerGlyph = document.querySelector<HTMLElement>(".entry-header > .glyph");
          const revealedGlyph = sealedKeySlots?.querySelector<HTMLElement>(".sealed-glyph-preview")?.outerHTML;
          if (headerGlyph && revealedGlyph) headerGlyph.outerHTML = revealedGlyph;
          if (sealedEntryId) sealedEntryId.textContent = fragment.id;
          if (sealedTitle) sealedTitle.textContent = fragment.title;
          if (sealedExcerpt) sealedExcerpt.innerHTML = renderInlineMarkdown(fragment.excerpt);
          if (sealedMeta) {
            sealedMeta.innerHTML = `
              <time datetime="${escapeHtml(fragment.date)}">${escapeHtml(date)}</time>
              <span>${escapeHtml(fragment.type)}</span>
              <span>${escapeHtml(fragment.medium.join(" / "))}</span>
            `;
            sealedMeta.hidden = false;
          }
          if (sealedTags) {
            sealedTags.innerHTML = fragment.tags.map((tag) => `<span>${escapeHtml(tag)}</span>`).join("");
            sealedTags.hidden = false;
          }

          sealedPlain.classList.remove("has-just-revealed");
          sealedPlain.innerHTML = `
            <div class="secret-fragment-body">${renderSecretBody(fragment.body)}</div>
          `;
          sealedPlain.hidden = false;
          sealedDecrypt.hidden = true;
          sealedDecrypt.disabled = true;
          sealedReset?.removeAttribute("hidden");
          if (sealedSeal) sealedSeal.hidden = true;
          sealedEntry?.classList.add("is-revealed");
          sealedStatus.textContent = "Fragment déchiffré.";

          if (options.animate) {
            sealedPlain.classList.add("has-just-revealed");
            window.setTimeout(() => sealedPlain.classList.remove("has-just-revealed"), 1300);
          }
        };

        const restoreSealedFragment = () => {
          if (sealedEntryId) sealedEntryId.textContent = initialHeader.id;
          if (sealedTitle) sealedTitle.textContent = initialHeader.title;
          if (sealedExcerpt) sealedExcerpt.textContent = initialHeader.excerpt;
          if (sealedMeta) {
            sealedMeta.hidden = true;
            sealedMeta.innerHTML = "";
          }
          if (sealedTags) {
            sealedTags.hidden = true;
            sealedTags.innerHTML = "";
          }
          if (sealedPlain) {
            sealedPlain.hidden = true;
            sealedPlain.innerHTML = "";
            sealedPlain.classList.remove("has-just-revealed");
          }
          if (sealedSeal) sealedSeal.hidden = false;
          sealedReset?.setAttribute("hidden", "");
          sealedEntry?.classList.remove("is-revealed", "is-decrypt-error", "is-decrypting", "is-reading", "is-condensing");
        };

        const updateDecryptButton = (ready: boolean) => {
          if (!sealedDecrypt) return;
          sealedDecrypt.hidden = !ready;
          sealedDecrypt.disabled = !ready;
          sealedDecrypt.textContent = "Déchiffrer";
        };

        const closePicker = () => {
          if (!activeColorTarget) return;
          window.clearTimeout(pickerCloseTimer);
          closingColorTarget = activeColorTarget;
          activeColorTarget = null;
          renderGlyphSlots();
          pickerCloseTimer = window.setTimeout(() => {
            closingColorTarget = null;
            renderGlyphSlots();
          }, 180);
        };

        const clampActiveColorTarget = () => {
          if (!activeColorTarget) return;

          if (glyphs.length === 0) {
            activeColorTarget = null;
            closingColorTarget = null;
            window.clearTimeout(pickerCloseTimer);
            return;
          }

          activeColorTarget = {
            glyphIndex: Math.min(activeColorTarget.glyphIndex, glyphs.length - 1),
            colorIndex: Math.min(Math.max(activeColorTarget.colorIndex, 0), 3),
          };
        };

        const renderGlyphSlots = () => {
          if (!sealedKeySlots) return;
          clampActiveColorTarget();

          sealedKeySlots.innerHTML =
            glyphs
              .map((glyph, index) => {
              const normalized = normalizeGlyph(glyph);
              const filledColors = filledSegments[index] ?? [false, false, false, false];
              const isEmpty = !hasAnyFilledSegment(index);
              const isComplete = filledColors.every(Boolean);
              const style = [
                `--glyph-a: ${normalized.colors[0]}`,
                `--glyph-b: ${normalized.colors[1]}`,
                `--glyph-c: ${normalized.colors[2]}`,
                `--glyph-d: ${normalized.colors[3]}`,
              ].join(";");
              const textureByColor: Record<string, string> = {
                "#d95f43": "/textures/orange-rouge.png",
                "#f2b84b": "/textures/jaune.png",
                "#e07a5f": "/textures/saumon.png",
                "#b94e5e": "/textures/rose-brique.png",
                "#2aa198": "/textures/cyan-vert.png",
                "#256d85": "/textures/bleu-petrole.png",
                "#3d7c68": "/textures/vert-froid.png",
                "#4f8fa8": "/textures/bleu-gris.png",
                "#455a7f": "/textures/bleu-ardoise.png",
                "#8f5b3e": "/textures/brun-rouille.png",
                "#5d4b7a": "/textures/violet-sourd.png",
                "#7b5ea7": "/textures/mauve.png",
                "#234f68": "/textures/bleu-profond.png",
                "#2f5f9b": "/textures/bleu-vif-profond.png",
                "#35675f": "/textures/vert-sombre.png",
                "#3f4a7a": "/textures/indigo-gris.png",
              };
              const grayTexture = "/textures/gris.png";
              const quadrantPaths = [
                "M150 150 L150 22 A128 128 0 0 1 278 150Z",
                "M150 150 L278 150 A128 128 0 0 1 150 278Z",
                "M150 150 L150 278 A128 128 0 0 1 22 150Z",
                "M150 150 L22 150 A128 128 0 0 1 150 22Z",
              ];
              const clipIds = quadrantPaths.map((_, colorIndex) => `sealed-${index}-${colorIndex}`);
              const imageTransforms = [180, 0, 0, 0].map((rotation, colorIndex) => {
                const moves = [
                  { x: 1.8, y: -1.2 },
                  { x: -1.5, y: 2.1 },
                  { x: 1.2, y: 1.5 },
                  { x: -0.9, y: -1.8 },
                ];
                return `rotate(${rotation} 150 150) translate(${moves[colorIndex].x} ${moves[colorIndex].y})`;
              });
              const glyphSvg = `
                <svg viewBox="0 0 300 300" width="100%" height="100%" preserveAspectRatio="xMidYMid meet">
                  <defs>${quadrantPaths.map((path, colorIndex) => `<clipPath id="${clipIds[colorIndex]}"><path d="${path}"></path></clipPath>`).join("")}</defs>
                  ${normalized.colors
                    .map((color, colorIndex) => {
                      const isFilled = filledColors[colorIndex] ?? false;
                      const texture = isFilled ? (textureByColor[color] ?? textureByColor["#d95f43"]) : grayTexture;
                      const filter = isFilled ? "" : `filter: brightness(${1.45 + colorIndex * 0.12}) contrast(${0.62 + colorIndex * 0.05});`;
                      return `
                        <g clip-path="url(#${clipIds[colorIndex]})" style="mix-blend-mode: multiply; opacity: 0.82; ${filter}">
                          <image href="${texture}" width="300" height="300" x="0" y="0" preserveAspectRatio="none" transform="${imageTransforms[colorIndex]}"></image>
                        </g>
                      `;
                    })
                    .join("")}
                </svg>
              `;
              const activeTarget = activeColorTarget?.glyphIndex === index ? activeColorTarget : null;
              const activeColorIndex = activeTarget?.colorIndex ?? 0;
              const segmentControls = [0, 1, 2, 3]
                .map((colorIndex) => {
                  const isActive = activeTarget?.colorIndex === colorIndex;
                  return `
                    <button
                      class="sealed-glyph-segment"
                      type="button"
                      data-glyph-segment="${colorIndex}"
                      data-glyph-id="${index}:${colorIndex}"
                      aria-pressed="${isActive}"
                      aria-label="Modifier la couleur ${colorIndex + 1} du glyphe ${index + 1}"
                    ></button>
                  `;
                })
                .join("");
              const colorSwatches = colorOptions
                .map((color, colorOptionIndex) => {
                  const isSelected = normalized.colors[activeColorIndex] === color.toLowerCase();
                  return `
                    <button
                      class="sealed-color-swatch"
                      type="button"
                      data-glyph-swatch="${color}"
                      aria-pressed="${isSelected}"
                      aria-label="Appliquer ${color}"
                      style="--swatch-color: ${color}; --swatch-angle: ${(360 / colorOptions.length) * colorOptionIndex}deg"
                    ></button>
                  `;
                })
                .join("");
              const closingTarget = closingColorTarget?.glyphIndex === index ? closingColorTarget : null;
              const visibleTarget = activeTarget ?? closingTarget;
              const pickerPanel = visibleTarget
                ? `
                  <div class="sealed-radial-picker ${closingTarget ? "is-closing" : shouldAnimatePicker ? "is-opening" : ""}" aria-label="Réglages du glyphe ${index + 1}">
                    ${colorSwatches}
                    <div class="sealed-glyph-control-row">
                      <button
                        class="sealed-picker-close"
                        type="button"
                        data-glyph-close
                        aria-label="Fermer le réglage du glyphe ${index + 1}"
                      >×</button>
                    </div>
                  </div>
                `
                : `<div class="sealed-color-placeholder" aria-hidden="true"></div>`;
              const slotCountClass = `sealed-slot-count-${glyphs.length}`;
              const slotClass = [
                "sealed-glyph-slot",
                slotCountClass,
                activeTarget ? "is-picker-open" : "",
                isEmpty ? "is-empty" : "",
                !isEmpty && !isComplete ? "is-partial" : "",
                isComplete ? "is-complete" : "",
              ]
                .filter(Boolean)
                .join(" ");

              return `
                <div class="${slotClass}" data-glyph-index="${index}">
                  <div class="sealed-glyph-instrument">
                    <div class="sealed-glyph-orb" style="${style}">
                      <span class="glyph sealed-glyph-preview" aria-hidden="true">${glyphSvg}</span>
                      ${segmentControls}
                    </div>
                  </div>
                  ${pickerPanel}
                </div>
              `;
            })
              .join("");

          sealedKeySlots.querySelectorAll<HTMLElement>("[data-glyph-index]").forEach((slot) => {
            const index = Number.parseInt(slot.dataset.glyphIndex ?? "0", 10);
            slot.querySelectorAll<HTMLButtonElement>("[data-glyph-segment]").forEach((button) => {
              button.addEventListener("click", () => {
                window.clearTimeout(pickerCloseTimer);
                closingColorTarget = null;
                const [glyphId, segmentId] = (button.dataset.glyphId ?? `${index}:0`).split(":");
                const nextTarget = {
                  glyphIndex: Number.parseInt(glyphId, 10) || 0,
                  colorIndex: Number.parseInt(segmentId, 10) || 0,
                };
                shouldAnimatePicker = activeColorTarget?.glyphIndex !== nextTarget.glyphIndex;
                activeColorTarget = nextTarget;
                renderGlyphSlots();
                shouldAnimatePicker = false;
              });
            });
            slot.querySelectorAll<HTMLButtonElement>("[data-glyph-swatch]").forEach((button) => {
              button.addEventListener("click", () => {
                const colorIndex = activeColorTarget?.glyphIndex === index ? activeColorTarget.colorIndex : 0;
                activeColorTarget = { glyphIndex: index, colorIndex };
                glyphs[index].colors[colorIndex] = button.dataset.glyphSwatch ?? glyphs[index].colors[colorIndex];
                filledSegments[index] = filledSegments[index] ?? [false, false, false, false];
                filledSegments[index][colorIndex] = true;
                renderGlyphSlots();
                queueValidation();
              });
            });
            slot.querySelector<HTMLButtonElement>("[data-glyph-close]")?.addEventListener("click", closePicker);
          });
        };

        const setGlyphs = (nextGlyphs: SealedGlyph[], { filled = true, slots = nextGlyphs.length }: { filled?: boolean; slots?: number } = {}) => {
          const slotCount = Math.max(1, slots);
          glyphs = Array.from({ length: slotCount }, (_, index) => normalizeGlyph(nextGlyphs[index] ?? getDefaultGlyph()));
          filledSegments = getEmptySegments(slotCount, filled);
          activeColorTarget = null;
          closingColorTarget = null;
          window.clearTimeout(pickerCloseTimer);
          renderGlyphSlots();
        };

        const validateGlyphs = async ({ silent = false } = {}) => {
          if (!sealedPayload || !sealedStatus) return false;

          const currentValidation = ++validationId;
          unlockedFragment = null;
          unlockedPassphrase = "";
          updateDecryptButton(false);

          if (glyphs.length !== 1) {
            if (!silent) sealedStatus.textContent = "Composez la clé visuelle du fragment.";
            return false;
          }
          if (!areGlyphsComplete()) {
            if (!silent) sealedStatus.textContent = "Complétez les glyphes.";
            return false;
          }

          if (!silent) sealedStatus.textContent = "Lecture de la combinaison.";

          const passphrase = getSealedPassphrase(glyphs);
          try {
            const fragment = await decryptPayload(passphrase);
            if (currentValidation !== validationId) return false;

            unlockedFragment = fragment;
            unlockedPassphrase = passphrase;
            storeKey(glyphs, passphrase);
            updateDecryptButton(true);
            sealedEntry?.classList.remove("is-decrypt-error");
            sealedStatus.textContent = "Combinaison prête.";
            return true;
          } catch {
            if (currentValidation !== validationId) return false;
            if (!silent) {
              sealedEntry?.classList.add("is-decrypt-error");
              sealedStatus.textContent = "Aucune ouverture pour cette combinaison.";
            }
            return false;
          }
        };

        const queueValidation = () => {
          window.clearTimeout(validationTimer);
          validationTimer = window.setTimeout(() => {
            void validateGlyphs();
          }, 260);
        };

        const loadSealedPayload = async () => {
          if (!sealedSlug || !sealedCipher || !sealedStatus || !sealedDecrypt) return;

          const response = await fetch(`/sealed/${sealedSlug}.json`);
          if (!response.ok) {
            sealedCipher.textContent = "Payload introuvable.";
            sealedStatus.textContent = "Le fragment scellé manque dans l'archive.";
            return;
          }

          sealedPayload = await response.json();
          sealedCipher.textContent = sealedPayload?.ciphertext ?? "";

          const storedFragment = readStoredFragment();
          if (storedFragment) {
            renderDecryptedFragment(storedFragment);
            return;
          }

          const storedKey = readStoredKey();
          const expectedSlots = 1;
          const hasStoredGlyphs = storedKey?.glyphs?.length === expectedSlots;
          const storedGlyphs = hasStoredGlyphs && storedKey?.glyphs ? storedKey.glyphs : [];
          setGlyphs(storedGlyphs, { filled: hasStoredGlyphs, slots: expectedSlots });
          sealedStatus.textContent = hasStoredGlyphs ? "Clé locale retrouvée." : "Composez la clé visuelle du fragment.";
          await validateGlyphs({ silent: !hasStoredGlyphs });
        };

        sealedDecrypt?.addEventListener("click", async () => {
          if (!sealedDecrypt || !sealedStatus || !sealedPlain) return;

          if (!unlockedFragment) await validateGlyphs();
          if (!unlockedFragment) return;

          sealedDecrypt.disabled = true;
          sealedDecrypt.textContent = "Déchiffrement...";
          sealedEntry?.classList.remove("is-decrypt-error");

          try {
            const ritual = playDecryptionRitual();
            await ritual;

            storeKey(glyphs, unlockedPassphrase);
            storeFragment(unlockedFragment);
            clearDecryptionState();
            renderDecryptedFragment(unlockedFragment, { animate: true });
          } catch {
            clearDecryptionState();
            sealedEntry?.classList.add("is-decrypt-error");
            sealedStatus.textContent = "La clé ne correspond pas à ce fragment.";
            sealedDecrypt.disabled = false;
            sealedDecrypt.textContent = "Réessayer";
          }
        });

        sealedReset?.addEventListener("click", () => {
          if (!sealedPlain || !sealedDecrypt || !sealedStatus) return;

          clearStoredFragment();
          clearStoredKey();
          unlockedFragment = null;
          unlockedPassphrase = "";
          restoreSealedFragment();
          updateDecryptButton(false);
          const expectedSlots = 1;
          setGlyphs([], { filled: false, slots: expectedSlots });
          sealedStatus.textContent = "Composez la clé visuelle du fragment.";
        });

        void loadSealedPayload();
      </script>
    </BaseLayout>
  ) : (
    <EntryLayout entry={entry}>
      {Content && <Content />}
    </EntryLayout>
  )
}
